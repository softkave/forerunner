{
  "name": "softkave-forerunner",
  "version": "0.4.2",
  "description": "softkave internal application runner & helpers",
  "author": {
    "email": "ywordk@gmail.com",
    "name": "softkave"
  },
  "license": "MIT",
  "homepage": "https://github.com/softkave/forerunner/tree/main/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/softkave/forerunner.git"
  },
  "bugs": {
    "url": "https://github.com/softkave/forerunner/issues"
  },
  "keywords": [],
  "type": "module",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "files": [
    "build/src/{*.js,**/*.js}",
    "build/src/{*.js.map,**/*.js.map}",
    "build/src/{*.d.ts,**/*.d.ts}",
    "!build/src/**/__tests__/**/*",
    "!build/src/**/testutils/**/*",
    "!build/src/private*"
  ],
  "bin": "build/src/bin.js",
  "scripts": {
    "test": "vitest",
    "lint": "gts lint",
    "clean": "gts clean && rm -f tsconfig.tsbuildinfo",
    "compile": "npm run clean && tsc",
    "fix": "gts fix",
    "posttest": "npm run lint",
    "publish:npm": "npm run clean && tsc && npm publish",
    "publish:yalc": "npm run clean && tsc && yalc publish",
    "show:packlist": "npm run clean && tsc && npm pack --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "22.2.0",
    "gts": "^6.0.2",
    "typescript": "~5.4.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.19.2",
    "fimidara": "^1.25.0",
    "find-process": "^2.0.0",
    "fs-extra": "^11.2.0",
    "generate-password": "^1.7.1",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "mongodb": "^6.19.0",
    "node-fetch": "^3.3.2",
    "softkave-js-utils": "^0.7.0",
    "type-fest": "^4.15.0",
    "zod": "^3.23.8",
    "zx": "^8.1.4"
  }
}
